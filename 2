function Show-AuditSubMenu {
    param([Parameter(Mandatory = $true)][ValidateSet('Enabled','All')][string]$AccountScope)

    while ($true) {
        Write-Host ""
        Write-Host "===== $AccountScope ACCOUNTS MENU =====" -ForegroundColor Cyan
        Write-Host "1. Sample Results (prompt for count)"
        Write-Host "2. Full Tenant Audit"
        Write-Host "3. Specific UPN(s)"
        Write-Host "4. Specific group object ID(s)"
        Write-Host "B. Back"

        $subChoice = Read-Host "Select an option"
        switch ($subChoice.ToUpper()) {
            '1' { $sampleSize = Get-SampleSize; $domainFilter = Get-DomainFilter; Run-Audit -Mode 'Sample' -AccountScope $AccountScope -SampleSize $sampleSize -DomainFilter $domainFilter }
            '2' { $domainFilter = Get-DomainFilter; Run-Audit -Mode 'Full' -AccountScope $AccountScope -DomainFilter $domainFilter }
            '3' { $upnFilter = Get-UpnFilter; if (@($upnFilter).Count -gt 0) { Run-Audit -Mode 'Targeted' -AccountScope $AccountScope -UpnFilter $upnFilter } else { Write-Host "No UPNs entered." -ForegroundColor Yellow } }
            '4' { $groupObjectIds = Get-GroupObjectIdFilter; if (@($groupObjectIds).Count -gt 0) { Run-Audit -Mode 'Group' -AccountScope $AccountScope -GroupObjectIdFilter $groupObjectIds } else { Write-Host "No group object IDs entered." -ForegroundColor Yellow } }
            'B' { return }
            default { Write-Host "Invalid selection." -ForegroundColor Red }
        }
    }
}

function Show-RemovalSubMenu {
    param(
        [Parameter(Mandatory = $true)][ValidateSet('Enabled','All')][string]$AccountScope,
        [switch]$AuditFirst
    )

    $label = if ($AuditFirst) { 'AUDIT + REMOVE' } else { 'REMOVAL' }

    while ($true) {
        Write-Host ""
        Write-Host "===== $AccountScope ACCOUNTS $label MENU =====" -ForegroundColor Cyan
        Write-Host "1. Sample Results (prompt for count)"
        Write-Host "2. Full Tenant"
        Write-Host "3. Specific UPN(s)"
        Write-Host "4. Specific group object ID(s)"
        Write-Host "B. Back"

        $subChoice = Read-Host "Select an option"
        switch ($subChoice.ToUpper()) {
            '1' { $sampleSize = Get-SampleSize; $domainFilter = Get-DomainFilter; Run-Removal -Mode 'Sample' -AccountScope $AccountScope -SampleSize $sampleSize -DomainFilter $domainFilter -AuditFirst:$AuditFirst }
            '2' { $domainFilter = Get-DomainFilter; Run-Removal -Mode 'Full' -AccountScope $AccountScope -DomainFilter $domainFilter -AuditFirst:$AuditFirst }
            '3' { $upnFilter = Get-UpnFilter; if (@($upnFilter).Count -gt 0) { Run-Removal -Mode 'Targeted' -AccountScope $AccountScope -UpnFilter $upnFilter -AuditFirst:$AuditFirst } else { Write-Host "No UPNs entered." -ForegroundColor Yellow } }
            '4' { $groupObjectIds = Get-GroupObjectIdFilter; if (@($groupObjectIds).Count -gt 0) { Run-Removal -Mode 'Group' -AccountScope $AccountScope -GroupObjectIdFilter $groupObjectIds -AuditFirst:$AuditFirst } else { Write-Host "No group object IDs entered." -ForegroundColor Yellow } }
            'B' { return }
            default { Write-Host "Invalid selection." -ForegroundColor Red }
        }
    }
}

# =========================
# MAIN MENU
# =========================
:mainLoop while ($true) {
    Write-Host "`n===== MAIN MENU =====" -ForegroundColor Cyan
    Write-Host "1. Disconnect / Reconnect Microsoft Graph"
    Write-Host "2. Audit Enabled Accounts"
    Write-Host "3. Audit All Accounts"
    Write-Host "4. Remove from Enabled Accounts"
    Write-Host "5. Remove from All Accounts"
    Write-Host "6. Audit + Remove from Enabled Accounts"
    Write-Host "7. Audit + Remove from All Accounts"
    Write-Host "8. Validate last removal results"
    Write-Host "Q. Quit"

    $choice = Read-Host "Select an option"

    switch ($choice.ToUpper()) {
        '1' { Connect-GraphSession }
        '2' { Show-AuditSubMenu -AccountScope 'Enabled' }
        '3' { Show-AuditSubMenu -AccountScope 'All' }
        '4' { Show-RemovalSubMenu -AccountScope 'Enabled' }
        '5' { Show-RemovalSubMenu -AccountScope 'All' }
        '6' { Show-RemovalSubMenu -AccountScope 'Enabled' -AuditFirst }
        '7' { Show-RemovalSubMenu -AccountScope 'All' -AuditFirst }
        '8' { Run-Validation }
        'Q' {
            Disconnect-GraphSession
            Write-Host "Exiting..." -ForegroundColor Yellow
            break mainLoop
        }
        default { Write-Host "Invalid selection." -ForegroundColor Red }
    }
}

